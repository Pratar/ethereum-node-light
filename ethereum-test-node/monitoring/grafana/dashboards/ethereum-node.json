{
  "dashboard": {
    "id": null,
    "title": "Ethereum Node Dashboard",
    "tags": ["ethereum", "blockchain"],
    "style": "dark",
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "Ethereum Node Status",
        "type": "stat",
        "targets": [
          {
            "expr": "up{job=\"ethereum-node\"}",
            "legendFormat": "Node Status"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "thresholds"
            },
            "thresholds": {
              "steps": [
                {"color": "red", "value": 0},
                {"color": "green", "value": 1}
              ]
            }
          }
        }
      },
      {
        "id": 2,
        "title": "Block Height",
        "type": "stat",
        "targets": [
          {
            "expr": "ethereum_chain_head_block",
            "legendFormat": "Current Block"
          }
        ]
      },
      {
        "id": 3,
        "title": "Peer Count",
        "type": "stat",
        "targets": [
          {
            "expr": "ethereum_p2p_peers",
            "legendFormat": "Active Peers"
          }
        ]
      },
      {
        "id": 4,
        "title": "Memory Usage",
        "type": "gauge",
        "targets": [
          {
            "expr": "(node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes) / node_memory_MemTotal_bytes * 100",
            "legendFormat": "Memory Usage %"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "min": 0,
            "max": 100,
            "thresholds": {
              "steps": [
                {"color": "green", "value": 0},
                {"color": "yellow", "value": 70},
                {"color": "red", "value": 90}
              ]
            }
          }
        }
      },
      {
        "id": 5,
        "title": "CPU Usage",
        "type": "timeseries",
        "targets": [
          {
            "expr": "100 - (avg by(instance) (irate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
            "legendFormat": "CPU Usage %"
          }
        ]
      },
      {
        "id": 6,
        "title": "Disk Usage",
        "type": "timeseries",
        "targets": [
          {
            "expr": "(node_filesystem_size_bytes - node_filesystem_free_bytes) / node_filesystem_size_bytes * 100",
            "legendFormat": "Disk Usage %"
          }
        ]
      },
      {
        "id": 7,
        "title": "RPC Requests",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rate(ethereum_rpc_requests_total[5m])",
            "legendFormat": "RPC Requests/sec"
          }
        ]
      },
      {
        "id": 8,
        "title": "Network Traffic",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rate(node_network_receive_bytes_total[5m])",
            "legendFormat": "Network Receive"
          },
          {
            "expr": "rate(node_network_transmit_bytes_total[5m])",
            "legendFormat": "Network Transmit"
          }
        ]
      }
    ],
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "refresh": "30s"
  }
} 